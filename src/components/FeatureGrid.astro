---
import type { Feature } from '../site.config';

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
  {
    features.map((feature) => (
      <article class="group rounded-2xl border border-white/15 bg-white/5 p-5 shadow-lg shadow-black/20 backdrop-blur-lg transition duration-300 hover:-translate-y-1 hover:border-gold/50 hover:bg-white/10">
        <h3 class="text-lg font-semibold text-white transition group-hover:text-gold">{feature.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-slate-300">{feature.description}</p>
      </article>
    ))
  }
</div>
