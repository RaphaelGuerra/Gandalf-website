---
interface Props {
  title: string;
  tagline: string;
  description: string;
  links: {
    github: string;
    moltbook: string;
  };
}

const { title, tagline, description, links } = Astro.props;
---

<section id="overview" class="reveal mx-auto w-full max-w-6xl px-4 pb-14 pt-14 sm:px-6 sm:pb-24 sm:pt-24">
  <div class="hero-glow rounded-3xl border border-gold/25 bg-black/20 p-6 shadow-2xl shadow-black/30 backdrop-blur-xl sm:p-12">
    <p class="mb-3 font-serif text-base text-gold/90 sm:mb-4 sm:text-lg">{tagline}</p>
    <h1 class="mb-4 text-4xl font-semibold leading-tight text-white sm:mb-5 sm:text-7xl">{title}</h1>
    <p class="max-w-3xl text-base leading-relaxed text-slate-200 sm:text-lg">{description}</p>

    <div class="mt-6 flex flex-wrap items-center gap-3 sm:mt-8">
      <a
        href={links.moltbook}
        target="_blank"
        rel="noreferrer"
        class="btn-primary"
      >
        Moltbook
      </a>
      <a
        href={links.github}
        target="_blank"
        rel="noreferrer"
        class="btn-secondary"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
