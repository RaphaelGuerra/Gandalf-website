---
interface Props {
  links: {
    github: string;
    moltbook: string;
  };
  note: string;
}

const { links, note } = Astro.props;
---

<footer id="links" class="mx-auto w-full max-w-6xl scroll-mt-28 px-4 pb-12 pt-6 sm:px-6 sm:pb-14 sm:pt-8">
  <div class="rounded-2xl border border-white/15 bg-black/25 p-5 backdrop-blur-xl sm:p-6">
    <div class="flex flex-wrap items-center gap-3">
      <a href={links.moltbook} target="_blank" rel="noreferrer" class="btn-primary">Moltbook</a>
      <a href={links.github} target="_blank" rel="noreferrer" class="btn-secondary">GitHub</a>
    </div>
    <p class="mt-4 text-sm text-slate-300">{note}</p>
    <p class="mt-2 text-xs text-slate-400">No copyrighted LOTR imagery. Original abstract rune motifs.</p>
  </div>
</footer>
