---
import type { NavItem } from '../site.config';

interface Props {
  nav: NavItem[];
  siteName: string;
}

const { nav, siteName } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-midnight/80 backdrop-blur-xl">
  <nav
    class="mx-auto flex w-full max-w-6xl flex-col items-start gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6 sm:py-4"
    aria-label="Primary"
  >
    <a href="#overview" class="font-serif text-base tracking-wide text-gold transition hover:text-gold-strong focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/80 sm:text-lg">
      {siteName}
    </a>
    <ul class="nav-scroll flex w-full items-center gap-1 overflow-x-auto pb-1 text-xs text-slate-200 sm:w-auto sm:gap-2 sm:overflow-visible sm:pb-0 sm:text-sm">
      {
        nav.map((item) => (
          <li class="shrink-0">
            <a
              href={item.href}
              class="block rounded-full px-3 py-1.5 transition hover:bg-white/10 hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/70 sm:py-2"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
